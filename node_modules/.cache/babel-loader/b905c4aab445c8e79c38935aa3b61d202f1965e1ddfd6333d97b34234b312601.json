{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport axios from 'axios';\n// Lembre-se de adicionar os scripts do Swiper e Chart.js no seu index.html\n\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      apiStatus: {\n        population: {\n          name: 'População (IBGE)',\n          isLoading: true,\n          error: null\n        },\n        victimization: {\n          name: 'Vitimização (API Demo)',\n          isLoading: true,\n          error: null\n        },\n        homicides: {\n          name: 'Homicídios (Banco Mundial)',\n          isLoading: true,\n          error: null\n        },\n        spending: {\n          name: 'Gastos em Segurança (IPEA)',\n          isLoading: true,\n          error: null\n        },\n        legislation: {\n          name: 'Legislação (Câmara)',\n          isLoading: true,\n          error: null\n        }\n      },\n      population: {\n        total: 0,\n        top3States: [],\n        ano: null\n      },\n      carouselSlides: {\n        isLoading: true,\n        error: null,\n        items: []\n      },\n      swiperInstance: null,\n      chartInstances: []\n    };\n  },\n  methods: {\n    async fetchAllData() {\n      const requests = {\n        population: axios.get('/api/contexto/populacao'),\n        victimization: axios.get('/api/paineis/vitimizacao'),\n        homicides: axios.get('/api/paineis/homicidios'),\n        spending: axios.get('/api/contexto/gastos-seguranca'),\n        legislation: axios.get('/api/contexto/legislacao-seguranca')\n      };\n      const results = await Promise.allSettled(Object.values(requests));\n      const keys = Object.keys(requests);\n      const successfulData = {};\n      results.forEach((result, index) => {\n        const key = keys[index];\n        this.apiStatus[key].isLoading = false;\n\n        // 👉 MELHORIA 1: Verificação de dados mais robusta\n        if (result.status === 'fulfilled' && result.value.data) {\n          const data = result.value.data;\n          // Checa se é um array não-vazio ou um objeto\n          if (Array.isArray(data) && data.length > 0 || typeof data === 'object' && !Array.isArray(data) && Object.keys(data).length > 0) {\n            successfulData[key] = data;\n            if (key === 'population') {\n              this.processPopulationData(data);\n            }\n          } else {\n            this.apiStatus[key].error = 'Dados não disponíveis.';\n          }\n        } else {\n          this.apiStatus[key].error = 'Falha na comunicação com a API.';\n          console.error(`Erro ou dados vazios para ${key}:`, result.reason || 'Resposta vazia');\n        }\n      });\n      this.generateCarouselSlides(successfulData);\n    },\n    processPopulationData(data) {\n      this.population.total = data.reduce((sum, state) => sum + state.populacao, 0);\n      // 👉 MELHORIA 4: Usando slice() para evitar mutação do array original\n      this.population.top3States = data.slice().sort((a, b) => b.populacao - a.populacao).slice(0, 3);\n      this.population.ano = data[0]?.ano || new Date().getFullYear() - 2;\n    },\n    generateCarouselSlides(allData) {\n      const pool = [];\n      if (allData.homicides) {\n        const latest = [...allData.homicides].sort((a, b) => b.ano - a.ano)[0];\n        pool.push({\n          type: 'kpi',\n          title: `Taxa de Homicídios (${latest.ano})`,\n          value: this.formatNumber(latest.taxa_por_100k),\n          unit: 'por 100.000 habitantes',\n          source: 'Banco Mundial / UNODC'\n        });\n        pool.push({\n          type: 'chart',\n          title: 'Evolução da Taxa de Homicídios',\n          source: 'Banco Mundial / UNODC',\n          chartType: 'line',\n          chartData: {\n            labels: allData.homicides.map(d => d.ano),\n            datasets: [{\n              label: 'Taxa por 100k',\n              data: allData.homicides.map(d => d.taxa_por_100k),\n              borderColor: '#fff',\n              tension: 0.1,\n              pointBackgroundColor: '#fff'\n            }]\n          }\n        });\n      }\n      if (allData.victimization) {\n        const crimeCounts = allData.victimization.reduce((acc, item) => {\n          acc[item.crime] = (acc[item.crime] || 0) + (item.ocorrencias || 0);\n          return acc;\n        }, {});\n        const topCrimes = Object.entries(crimeCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);\n        pool.push({\n          type: 'chart',\n          title: 'Top 5 Crimes (Vitimização)',\n          source: 'API Vitimização (Demo)',\n          chartType: 'bar',\n          chartData: {\n            labels: topCrimes.map(c => c[0]),\n            datasets: [{\n              label: 'Ocorrências',\n              data: topCrimes.map(c => c[1]),\n              backgroundColor: 'rgba(255, 255, 255, 0.7)'\n            }]\n          }\n        });\n      }\n      if (allData.legislation) {\n        const latest = allData.legislation[0];\n        pool.push({\n          type: 'kpi',\n          title: 'Última Proposição Legislativa',\n          value: `${latest.sigla} ${latest.numero}/${latest.ano}`,\n          unit: 'relacionada à segurança pública',\n          source: 'Câmara dos Deputados'\n        });\n      }\n      if (pool.length === 0) {\n        this.carouselSlides = {\n          isLoading: false,\n          error: 'Não foi possível gerar destaques hoje.'\n        };\n        return;\n      }\n      this.carouselSlides = {\n        items: pool,\n        isLoading: false,\n        error: null\n      };\n      this.$nextTick(() => {\n        this.initSwiper();\n        this.renderCharts();\n      });\n    },\n    initSwiper() {\n      // 👉 MELHORIA 2: Verificação segura antes de destruir\n      if (this.swiperInstance && !this.swiperInstance.destroyed) {\n        this.swiperInstance.destroy(true, true);\n      }\n      // eslint-disable-next-line\n      this.swiperInstance = new Swiper('.swiper', {\n        effect: 'coverflow',\n        grabCursor: true,\n        centeredSlides: true,\n        slidesPerView: 'auto',\n        loop: true,\n        coverflowEffect: {\n          rotate: 50,\n          stretch: 0,\n          depth: 100,\n          modifier: 1,\n          slideShadows: true\n        },\n        navigation: {\n          nextEl: '.swiper-button-next',\n          prevEl: '.swiper-button-prev'\n        },\n        autoplay: {\n          delay: 5000,\n          disableOnInteraction: false\n        }\n      });\n    },\n    renderCharts() {\n      this.chartInstances.forEach(chart => chart.destroy());\n      this.chartInstances = [];\n      this.carouselSlides.items.forEach((slide, index) => {\n        if (slide.type === 'chart') {\n          const ctx = document.getElementById(`chart-${index}`);\n          // 👉 MELHORIA 3: Verificação segura do contexto do canvas\n          if (ctx && ctx.getContext) {\n            // eslint-disable-next-line\n            const chart = new Chart(ctx, {\n              type: slide.chartType,\n              data: slide.chartData,\n              options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: {\n                  legend: {\n                    labels: {\n                      color: '#fff'\n                    }\n                  }\n                },\n                scales: {\n                  y: {\n                    ticks: {\n                      color: '#fff'\n                    },\n                    grid: {\n                      color: 'rgba(255,255,255,0.2)'\n                    }\n                  },\n                  x: {\n                    ticks: {\n                      color: '#fff'\n                    },\n                    grid: {\n                      color: 'rgba(255,255,255,0.2)'\n                    }\n                  }\n                }\n              }\n            });\n            this.chartInstances.push(chart);\n          }\n        }\n      });\n    },\n    formatNumber(num) {\n      if (typeof num !== 'number') return '...';\n      return num.toLocaleString('pt-BR');\n    }\n  },\n  created() {\n    this.fetchAllData();\n  },\n  beforeUnmount() {\n    if (this.swiperInstance) this.swiperInstance.destroy();\n    this.chartInstances.forEach(chart => chart.destroy());\n  }\n};","map":{"version":3,"names":["axios","name","data","apiStatus","population","isLoading","error","victimization","homicides","spending","legislation","total","top3States","ano","carouselSlides","items","swiperInstance","chartInstances","methods","fetchAllData","requests","get","results","Promise","allSettled","Object","values","keys","successfulData","forEach","result","index","key","status","value","Array","isArray","length","processPopulationData","console","reason","generateCarouselSlides","reduce","sum","state","populacao","slice","sort","a","b","Date","getFullYear","allData","pool","latest","push","type","title","formatNumber","taxa_por_100k","unit","source","chartType","chartData","labels","map","d","datasets","label","borderColor","tension","pointBackgroundColor","crimeCounts","acc","item","crime","ocorrencias","topCrimes","entries","c","backgroundColor","sigla","numero","$nextTick","initSwiper","renderCharts","destroyed","destroy","Swiper","effect","grabCursor","centeredSlides","slidesPerView","loop","coverflowEffect","rotate","stretch","depth","modifier","slideShadows","navigation","nextEl","prevEl","autoplay","delay","disableOnInteraction","chart","slide","ctx","document","getElementById","getContext","Chart","options","responsive","maintainAspectRatio","plugins","legend","color","scales","y","ticks","grid","x","num","toLocaleString","created","beforeUnmount"],"sources":["C:\\Users\\pedro\\OneDrive\\Documentos\\GitHub\\Pulso-Urbano\\frontend\\src\\views\\Home.vue"],"sourcesContent":["<template>\r\n  <main>\r\n    <section class=\"hero\">\r\n      <div class=\"hero-content\">\r\n        <h2>Democratizando dados e análises sobre segurança pública e justiça no Brasil.</h2>\r\n        <p>O Pulso Urbano integra dados de vitimização e registros administrativos para revelar um panorama completo\r\n          sobre a criminalidade e o acesso à justiça no país.</p>\r\n        <a href=\"#paineis\" class=\"btn-primary\">Explorar os Painéis</a>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- SEÇÃO DE DESTAQUES COM CARROSSEL CORRIGIDO -->\r\n    <section class=\"highlight-section\">\r\n      <h2 class=\"section-title\">Destaques</h2>\r\n      <div v-if=\"carouselSlides.isLoading\" class=\"status-message\">\r\n        <div class=\"spinner-large\"></div>\r\n        <p>Gerando destaques...</p>\r\n      </div>\r\n      <div v-else-if=\"carouselSlides.error\" class=\"status-message error\">\r\n        {{ carouselSlides.error }}\r\n      </div>\r\n      <!-- Estrutura do Carrossel (Swiper) -->\r\n      <div v-else class=\"swiper-container\">\r\n        <div class=\"swiper\">\r\n          <div class=\"swiper-wrapper\">\r\n            <!-- Slides são gerados dinamicamente -->\r\n            <div class=\"swiper-slide\" v-for=\"(slide, index) in carouselSlides.items\" :key=\"index\">\r\n              <article class=\"card card-highlight\">\r\n                <h3>{{ slide.title }}</h3>\r\n                <!-- Renderiza um gráfico se o tipo for 'chart' -->\r\n                <div v-if=\"slide.type === 'chart'\" class=\"chart-container\">\r\n                  <canvas :id=\"'chart-' + index\"></canvas>\r\n                </div>\r\n                <!-- Renderiza um KPI se o tipo for 'kpi' -->\r\n                <div v-else>\r\n                  <p class=\"highlight-value\">{{ slide.value }}</p>\r\n                  <span class=\"highlight-unit\">{{ slide.unit }}</span>\r\n                </div>\r\n                <span class=\"highlight-source\">Fonte: {{ slide.source }}</span>\r\n              </article>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <!-- Botões de Navegação -->\r\n        <div class=\"swiper-button-prev\"></div>\r\n        <div class=\"swiper-button-next\"></div>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"featured-section\" id=\"paineis\">\r\n      <h2 class=\"section-title\">Painéis de Dados</h2>\r\n      <div class=\"card-container\">\r\n        <article class=\"card\">\r\n          <h3>Monitor do Homicídio</h3>\r\n          <p>Análise detalhada das taxas de homicídios dolosos, perfil das vítimas e o impacto do crime organizado.</p>\r\n          <div class=\"card-footer\">\r\n            <a href=\"/paineis/homicidios\" class=\"card-link\">Acessar Painel</a>\r\n            <span v-if=\"apiStatus.homicides.isLoading\" class=\"status-badge loading\"><div class=\"spinner-badge\"></div></span>\r\n            <span v-else-if=\"apiStatus.homicides.error\" class=\"status-badge error\">Offline</span>\r\n            <span v-else class=\"status-badge online\">Online</span>\r\n          </div>\r\n        </article>\r\n        <article class=\"card\">\r\n          <h3>Atlas da Vitimização</h3>\r\n          <p>Explore dados sobre crimes reportados e não reportados à polícia, baseados em pesquisas de vitimização.</p>\r\n           <div class=\"card-footer\">\r\n            <a href=\"/paineis/vitimizacao\" class=\"card-link\">Acessar Painel</a>\r\n            <span v-if=\"apiStatus.victimization.isLoading\" class=\"status-badge loading\"><div class=\"spinner-badge\"></div></span>\r\n            <span v-else-if=\"apiStatus.victimization.error\" class=\"status-badge error\">Offline</span>\r\n            <span v-else class=\"status-badge online\">Online</span>\r\n          </div>\r\n        </article>\r\n        <article class=\"card disabled\">\r\n          <h3>Observatório da Violência de Gênero</h3>\r\n          <p>Dados sobre feminicídio e violência doméstica, revelando o lar como um dos espaços mais perigosos para mulheres.</p>\r\n           <div class=\"card-footer\">\r\n            <a href=\"#\" class=\"card-link\">Em breve</a>\r\n            <span class=\"status-badge neutral\">Pendente</span>\r\n          </div>\r\n        </article>\r\n      </div>\r\n    </section>\r\n    \r\n    <section class=\"context-section\">\r\n      <h2 class=\"section-title\">Contexto Nacional <span class=\"data-source\">(IBGE, {{ population.ano || '...' }})</span></h2>\r\n      <div v-if=\"apiStatus.population.isLoading\" class=\"status-message\">\r\n        <div class=\"spinner-large\"></div>\r\n        <p>Carregando dados populacionais...</p>\r\n      </div>\r\n      <div v-else-if=\"apiStatus.population.error\" class=\"status-message error\">{{ apiStatus.population.error }}</div>\r\n      <div v-else class=\"card-container\" id=\"ibge-data-container\">\r\n        <article class=\"card card-data-highlight\">\r\n            <h3>População Total do Brasil</h3>\r\n            <p class=\"data-value\">{{ formatNumber(population.total) }}</p>\r\n        </article>\r\n        <article class=\"card\" v-for=\"state in population.top3States\" :key=\"state.uf\">\r\n            <h3>{{ state.uf }}</h3>\r\n            <p class=\"data-value\">{{ formatNumber(state.populacao) }}</p>\r\n        </article>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"api-status-section\">\r\n        <h2 class=\"section-title\">Status das Fontes de Dados</h2>\r\n        <div class=\"status-list\">\r\n            <div v-for=\"(status, key) in apiStatus\" :key=\"key\" class=\"status-item\">\r\n                <span class=\"status-name\">{{ status.name }}</span>\r\n                <span v-if=\"status.isLoading\" class=\"status-badge loading\"><div class=\"spinner-badge\"></div> Carregando...</span>\r\n                <span v-else-if=\"status.error\" class=\"status-badge error\">Erro</span>\r\n                <span v-else class=\"status-badge online\">Operacional</span>\r\n            </div>\r\n        </div>\r\n    </section>\r\n  </main>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios';\r\n// Lembre-se de adicionar os scripts do Swiper e Chart.js no seu index.html\r\n\r\nexport default {\r\n  name: 'HomeView',\r\n  data() {\r\n    return {\r\n      apiStatus: {\r\n        population:   { name: 'População (IBGE)', isLoading: true, error: null },\r\n        victimization:{ name: 'Vitimização (API Demo)', isLoading: true, error: null },\r\n        homicides:    { name: 'Homicídios (Banco Mundial)', isLoading: true, error: null },\r\n        spending:     { name: 'Gastos em Segurança (IPEA)', isLoading: true, error: null },\r\n        legislation:  { name: 'Legislação (Câmara)', isLoading: true, error: null },\r\n      },\r\n      population: {\r\n        total: 0,\r\n        top3States: [],\r\n        ano: null,\r\n      },\r\n      carouselSlides: {\r\n        isLoading: true,\r\n        error: null,\r\n        items: [],\r\n      },\r\n      swiperInstance: null,\r\n      chartInstances: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async fetchAllData() {\r\n      const requests = {\r\n        population: axios.get('/api/contexto/populacao'),\r\n        victimization: axios.get('/api/paineis/vitimizacao'),\r\n        homicides: axios.get('/api/paineis/homicidios'),\r\n        spending: axios.get('/api/contexto/gastos-seguranca'),\r\n        legislation: axios.get('/api/contexto/legislacao-seguranca'),\r\n      };\r\n\r\n      const results = await Promise.allSettled(Object.values(requests));\r\n      const keys = Object.keys(requests);\r\n      const successfulData = {};\r\n\r\n      results.forEach((result, index) => {\r\n        const key = keys[index];\r\n        this.apiStatus[key].isLoading = false;\r\n        \r\n        // 👉 MELHORIA 1: Verificação de dados mais robusta\r\n        if (result.status === 'fulfilled' && result.value.data) {\r\n          const data = result.value.data;\r\n          // Checa se é um array não-vazio ou um objeto\r\n          if ((Array.isArray(data) && data.length > 0) || (typeof data === 'object' && !Array.isArray(data) && Object.keys(data).length > 0)) {\r\n            successfulData[key] = data;\r\n            if (key === 'population') {\r\n              this.processPopulationData(data);\r\n            }\r\n          } else {\r\n            this.apiStatus[key].error = 'Dados não disponíveis.';\r\n          }\r\n        } else {\r\n          this.apiStatus[key].error = 'Falha na comunicação com a API.';\r\n          console.error(`Erro ou dados vazios para ${key}:`, result.reason || 'Resposta vazia');\r\n        }\r\n      });\r\n      \r\n      this.generateCarouselSlides(successfulData);\r\n    },\r\n    processPopulationData(data) {\r\n      this.population.total = data.reduce((sum, state) => sum + state.populacao, 0);\r\n      // 👉 MELHORIA 4: Usando slice() para evitar mutação do array original\r\n      this.population.top3States = data.slice().sort((a, b) => b.populacao - a.populacao).slice(0, 3);\r\n      this.population.ano = data[0]?.ano || new Date().getFullYear() - 2;\r\n    },\r\n    generateCarouselSlides(allData) {\r\n      const pool = [];\r\n\r\n      if (allData.homicides) {\r\n        const latest = [...allData.homicides].sort((a, b) => b.ano - a.ano)[0];\r\n        pool.push({\r\n          type: 'kpi', title: `Taxa de Homicídios (${latest.ano})`,\r\n          value: this.formatNumber(latest.taxa_por_100k), unit: 'por 100.000 habitantes', source: 'Banco Mundial / UNODC'\r\n        });\r\n        pool.push({\r\n          type: 'chart', title: 'Evolução da Taxa de Homicídios',\r\n          source: 'Banco Mundial / UNODC', chartType: 'line',\r\n          chartData: {\r\n            labels: allData.homicides.map(d => d.ano),\r\n            datasets: [{ label: 'Taxa por 100k', data: allData.homicides.map(d => d.taxa_por_100k), borderColor: '#fff', tension: 0.1, pointBackgroundColor: '#fff' }]\r\n          }\r\n        });\r\n      }\r\n      if (allData.victimization) {\r\n        const crimeCounts = allData.victimization.reduce((acc, item) => {\r\n            acc[item.crime] = (acc[item.crime] || 0) + (item.ocorrencias || 0);\r\n            return acc;\r\n        }, {});\r\n        const topCrimes = Object.entries(crimeCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);\r\n        pool.push({\r\n          type: 'chart', title: 'Top 5 Crimes (Vitimização)',\r\n          source: 'API Vitimização (Demo)', chartType: 'bar',\r\n          chartData: {\r\n            labels: topCrimes.map(c => c[0]),\r\n            datasets: [{ label: 'Ocorrências', data: topCrimes.map(c => c[1]), backgroundColor: 'rgba(255, 255, 255, 0.7)' }]\r\n          }\r\n        });\r\n      }\r\n      if (allData.legislation) {\r\n        const latest = allData.legislation[0];\r\n        pool.push({\r\n          type: 'kpi', title: 'Última Proposição Legislativa',\r\n          value: `${latest.sigla} ${latest.numero}/${latest.ano}`, unit: 'relacionada à segurança pública', source: 'Câmara dos Deputados'\r\n        });\r\n      }\r\n\r\n      if (pool.length === 0) {\r\n        this.carouselSlides = { isLoading: false, error: 'Não foi possível gerar destaques hoje.' };\r\n        return;\r\n      }\r\n      this.carouselSlides = { items: pool, isLoading: false, error: null };\r\n      \r\n      this.$nextTick(() => {\r\n        this.initSwiper();\r\n        this.renderCharts();\r\n      });\r\n    },\r\n    initSwiper() {\r\n        // 👉 MELHORIA 2: Verificação segura antes de destruir\r\n        if (this.swiperInstance && !this.swiperInstance.destroyed) {\r\n          this.swiperInstance.destroy(true, true);\r\n        }\r\n        // eslint-disable-next-line\r\n        this.swiperInstance = new Swiper('.swiper', {\r\n            effect: 'coverflow',\r\n            grabCursor: true,\r\n            centeredSlides: true,\r\n            slidesPerView: 'auto',\r\n            loop: true,\r\n            coverflowEffect: {\r\n              rotate: 50,\r\n              stretch: 0,\r\n              depth: 100,\r\n              modifier: 1,\r\n              slideShadows: true,\r\n            },\r\n            navigation: {\r\n                nextEl: '.swiper-button-next',\r\n                prevEl: '.swiper-button-prev',\r\n            },\r\n            autoplay: {\r\n                delay: 5000,\r\n                disableOnInteraction: false,\r\n            },\r\n        });\r\n    },\r\n    renderCharts() {\r\n        this.chartInstances.forEach(chart => chart.destroy());\r\n        this.chartInstances = [];\r\n\r\n        this.carouselSlides.items.forEach((slide, index) => {\r\n            if (slide.type === 'chart') {\r\n                const ctx = document.getElementById(`chart-${index}`);\r\n                // 👉 MELHORIA 3: Verificação segura do contexto do canvas\r\n                if (ctx && ctx.getContext) {\r\n                    // eslint-disable-next-line\r\n                    const chart = new Chart(ctx, {\r\n                        type: slide.chartType,\r\n                        data: slide.chartData,\r\n                        options: {\r\n                            responsive: true,\r\n                            maintainAspectRatio: false,\r\n                            plugins: { legend: { labels: { color: '#fff' } } },\r\n                            scales: {\r\n                                y: { ticks: { color: '#fff' }, grid: { color: 'rgba(255,255,255,0.2)' } },\r\n                                x: { ticks: { color: '#fff' }, grid: { color: 'rgba(255,255,255,0.2)' } }\r\n                            }\r\n                        }\r\n                    });\r\n                    this.chartInstances.push(chart);\r\n                }\r\n            }\r\n        });\r\n    },\r\n    formatNumber(num) {\r\n      if (typeof num !== 'number') return '...';\r\n      return num.toLocaleString('pt-BR');\r\n    },\r\n  },\r\n  created() {\r\n    this