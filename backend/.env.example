# Porta local do servidor
PORT=3000

# PostgreSQL (NeonDB) — produção/rotas legadas
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Banco v2 de DESENVOLVIMENTO (Docker): docker compose -f database/docker-compose.yml up -d
# As rotas v2 usam SOMENTE este banco nas Fases 3/4. Em produção (Fase 5),
# em vez de definir isto, use V2_USE_PROD=1 para liberar o fallback à DATABASE_URL.
TEST_DATABASE_URL=postgresql://pulso:pulso_dev@localhost:5433/pulso_urbano

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=seu_jwt_secret_aqui

# E-mail transacional (Resend — doc 08). SEM esta chave em dev: e-mails viram
# no-op (logados no console), fluxos de conta seguem funcionando.
RESEND_API_KEY=
EMAIL_FROM=Pulso Urbano <nao-responda@pulsourbano.org>
# Base p/ links absolutos nos e-mails (verificação/reset). Em prod: URL do site.
APP_URL=http://localhost:5173

# Cloudflare R2 (armazenamento de arquivos)
STORAGE_PUBLIC_URL=https://seu-bucket.r2.dev
STORAGE_BUCKET_NAME=nome-do-bucket
STORAGE_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ASSESS_KEY_ID=sua_access_key_id
STORAGE_SECRET_ACCESS_KEY=sua_secret_access_key

# Upstash Redis — rate limiting do login admin E cache server-side (opcional em dev).
# Crie um banco gratuito em https://console.upstash.com e copie os valores REST.
# Se ausentes: rate limiting desativado e cache cai para memória (não persiste no serverless).
UPSTASH_REDIS_REST_URL=https://seu-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_token_rest

# Nota: credenciais de admin não ficam mais no .env.
# Crie admins diretamente no banco usando database/schema.sql.
