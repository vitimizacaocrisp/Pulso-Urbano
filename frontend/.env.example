# API base URL.
# VAZIO = mesma origem (dev usa o proxy do Vite → http://localhost:3000;
# produção usa o proxy do Netlify). Só preencha para apontar à produção.
VITE_API_URL=

# EmailJS — usado pelo formulário da página de Contato (ContatoView.vue).
# Crie uma conta em https://www.emailjs.com e configure:
#   1. Um Email Service  → copie o Service ID
#   2. Um Email Template  → copie o Template ID
#        (use as variáveis: {{from_name}}, {{reply_to}}, {{subject}}, {{message}})
#   3. Account → API Keys → copie a Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
